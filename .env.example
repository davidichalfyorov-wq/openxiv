# Runtime
NODE_ENV=development # Runtime mode.
LOG_LEVEL=info # Server log level.
API_PORT=4000 # API listen port.
WEB_PORT=4321 # Web listen port.
USE_MOCK_CLIENTS=true # Use all local mock clients.
USE_MOCK_LLM=true # Mock LLM calls.
USE_MOCK_GROBID=true # Mock GROBID calls.
USE_MOCK_TECTONIC=true # Mock Tectonic compile calls.
USE_MOCK_LATEXML=true # Mock LaTeXML calls.
USE_MOCK_DETECTOR=true # Mock AI detector calls.
USE_MOCK_ORCID=true # Mock ORCID OAuth calls.
USE_MOCK_BLUESKY=true # Mock Bluesky calls.

# Public urls
PUBLIC_API_BASE=http://localhost:4000 # Public API base URL.
PUBLIC_WEB_BASE=http://localhost:4321 # Public web base URL.
CORS_ORIGINS=http://localhost:4321 # Allowed browser origins.

# Database
DATABASE_URL=postgres://openxiv:openxiv@localhost:5432/openxiv # Postgres connection string.

# Redis
REDIS_URL=redis://localhost:6379 # Redis connection string.

# Storage
S3_ENDPOINT=http://localhost:9000 # S3 API endpoint.
S3_PUBLIC_ENDPOINT=http://localhost:9000 # Public S3 download endpoint.
S3_REGION=auto # S3 region.
S3_ACCESS_KEY_ID=minioadmin # Local MinIO access key.
S3_SECRET_ACCESS_KEY=minioadmin # Local MinIO secret key.
S3_BUCKET=openxiv-blobs # Object bucket name.
S3_FORCE_PATH_STYLE=true # Use path-style S3 URLs.

# Auth providers
ORCID_CLIENT_ID= # ORCID client id.
ORCID_CLIENT_SECRET= # ORCID client secret.
ORCID_REDIRECT_URI=http://localhost:4000/auth/orcid/callback # ORCID callback URL.
ORCID_USE_SANDBOX=true # Use ORCID sandbox.
GOOGLE_CLIENT_ID= # Google OAuth client id.
GOOGLE_CLIENT_SECRET= # Google OAuth client secret.
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback # Google callback URL.
BLUESKY_OAUTH_CLIENT_ID=http://localhost # Bluesky OAuth client metadata URL.
BLUESKY_OAUTH_REDIRECT_URI=http://localhost:4000/auth/bluesky/callback # Bluesky callback URL.
ATPROTO_SERVICE_URL=https://bsky.social # AT Protocol service URL.
SESSION_SECRET=dev-session-secret-please-replace-32-chars-min # Session signing secret.
JWT_SECRET=dev-jwt-secret-please-replace-32-chars-min # JWT signing secret.
JWT_TTL_SECONDS=2592000 # JWT lifetime in seconds.

# Llm
DEEPSEEK_API_KEY= # DeepSeek API key.
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1 # DeepSeek API base URL.
DEEPSEEK_MODEL_TEXT=deepseek-v4-flash # DeepSeek text model.
GEMINI_API_KEY= # Gemini API key.
GEMINI_MODEL_TEXT=gemini-2.5-flash # Gemini text model.
GEMINI_MODEL_EMBED=gemini-embedding-001 # Gemini embedding model.
LLM_EMBED_TOKENS_DAILY=1000000 # Daily embedding token cap.
LLM_TEXT_TOKENS_DAILY=200000 # Daily text token cap.
LLM_EXPLAIN_PER_USER_DAILY=30 # Daily explain cap per user.

# Indexing
GROBID_URL=http://localhost:8070 # GROBID service URL.
TECTONIC_DOCKER_IMAGE=openxiv/tectonic:latest # Tectonic image name.
TECTONIC_TIMEOUT_MS=180000 # Tectonic timeout in milliseconds.
LATEXML_TIMEOUT_MS=180000 # LaTeXML timeout in milliseconds.
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe # Jetstream endpoint.
FEED_GENERATOR_DID=did:web:openxiv.net # Feed generator DID.
FEED_GENERATOR_PUBLIC_URL=http://localhost:4400 # Feed generator public URL.
INDEXNOW_KEY= # IndexNow ownership key.
SEARCH_RATE_PER_IP_PER_MIN=30 # Search calls per IP per minute.
SEARCH_CACHE_TTL_SECONDS=300 # Search cache TTL in seconds.

# Detection
DETECTOR_GPT2_MODEL_PATH=models/gpt2-medium # GPT-2 detector model path.
DETECTOR_BURST_WEIGHT=0.4 # Burst score weight.
DETECTOR_BINOCULARS_WEIGHT=0.4 # Binoculars score weight.
DETECTOR_STYLOMETRIC_WEIGHT=0.2 # Stylometric score weight.

# Operations
RATE_LIMIT_MAX=60 # Request cap per window.
RATE_LIMIT_WINDOW_MS=60000 # Rate limit window in milliseconds.
SENTRY_DSN= # Sentry DSN.
SENTRY_RELEASE= # Sentry release label.
SENTRY_TRACES_SAMPLE_RATE=0 # Sentry trace sample rate.
ADMIN_DIDS= # Comma-separated admin DIDs.
SUBMIT_ALLOW_DIDS= # Comma-separated submit allowlist.
