{
  "name": "@openxiv/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').cpSync('src/services/brand', 'dist/services/brand', { recursive: true })\"",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bsky:register-feeds": "tsx src/scripts/register-bsky-feeds.ts",
    "bsky:smoke": "tsx src/scripts/bsky-smoke.ts"
  },
  "dependencies": {
    "@atproto/api": "^0.19.18",
    "@atproto/identity": "^0.4.12",
    "@atproto/syntax": "^0.5.4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@openxiv/clients": "workspace:*",
    "@openxiv/db": "workspace:*",
    "@openxiv/lexicons": "workspace:*",
    "@openxiv/shared": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.53.1",
    "@types/ws": "^8.18.1",
    "bullmq": "^5.34.4",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "isomorphic-dompurify": "^3.13.0",
    "jose": "^5.9.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "ws": "^8.20.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ioredis-mock": "^8.2.5",
    "@types/qrcode": "^1.5.6",
    "fast-check": "^3.23.2",
    "ioredis-mock": "^8.9.0",
    "nock": "^14.0.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "AGPL-3.0-or-later"
}
