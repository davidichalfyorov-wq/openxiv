---
import Base from '../../../layouts/Base.astro';

const sourceParam = Astro.params.source;
const idParam = Astro.params.id;
if (!sourceParam || !idParam) {
  return new Response('Missing source or id', { status: 400 });
}
if (sourceParam !== 'arxiv') {
  // Only arxiv ships in MVP — other sources route to a friendly 404.
  return new Response('Unsupported source', { status: 404 });
}

const apiBase =
  (typeof process !== 'undefined' && process.env?.INTERNAL_API_BASE) ||
  import.meta.env.PUBLIC_API_BASE ||
  'http://localhost:4000';

interface LensResponse {
  source: string;
  sourceId: string;
  title: string;
  authors: Array<{ name: string; affiliation?: string; orcid?: string }>;
  abstract: string | null;
  categories: string[];
  doi: string | null;
  url: string | null;
  license: string | null;
  publishedAt: string | null;
  withdrawn: boolean;
  fetchedAt: string;
  claimedByDid: string | null;
  claimedAt: string | null;
}

let paper: LensResponse | null = null;
let error: string | null = null;
try {
  const res = await fetch(
    `${apiBase}/api/lens/${encodeURIComponent(sourceParam)}/${encodeURIComponent(idParam)}`,
    { signal: AbortSignal.timeout(15_000) },
  );
  if (res.ok) {
    paper = (await res.json()) as LensResponse;
  } else if (res.status === 404) {
    error = 'Paper not found in ' + sourceParam;
  } else {
    error = `Upstream returned ${res.status}`;
  }
} catch (e) {
  error = (e as Error).message;
}

const sourceLabel: Record<string, string> = { arxiv: 'arXiv' };
const upstreamHref =
  paper?.url ?? (sourceParam === 'arxiv' ? `https://arxiv.org/abs/${idParam}` : null);
---
<Base
  title={paper ? `Lens — ${paper.title}` : `OpenXiv Lens — ${sourceParam}:${idParam}`}
  description={paper?.abstract?.slice(0, 200) ?? `OpenXiv Lens view of ${sourceParam}:${idParam}.`}
>
  <Fragment slot="head">
    {/*
      Lens pages are proxy views of external content — they MUST NOT be
      indexed, both for SEO duplication reasons and because the underlying
      paper isn't ours.
    */}
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <main class="container">
    <p class="muted lens-trail">
      <a href="/">← home</a> · OpenXiv Lens
    </p>

    {error && (
      <article class="card" style="border-color: var(--tone-caution);">
        <strong>Lens unavailable.</strong>
        <p class="muted" style="margin:6px 0 0;">{error}</p>
      </article>
    )}

    {paper && (
      <article class="lens">
        <header class="lens-head">
          <span class="lens-source">{sourceLabel[paper.source] ?? paper.source}</span>
          <code class="muted lens-id">{paper.sourceId}</code>
          {paper.withdrawn && <span class="lens-withdrawn">Withdrawn</span>}
        </header>
        <h1 class="title-serif lens-title">{paper.title}</h1>
        <p class="muted lens-byline">
          {paper.authors.map((a) => a.name).join(', ') || '—'}
          {paper.publishedAt && <span> · {paper.publishedAt.slice(0, 10)}</span>}
        </p>
        {paper.categories.length > 0 && (
          <p class="muted lens-cats">
            {paper.categories.map((c) => (
              <code style="margin-right: 6px;">{c}</code>
            ))}
          </p>
        )}

        <section class="card lens-section">
          <h2>About this view</h2>
          <p class="muted">
            This is an OpenXiv Lens — a proxy view of a paper hosted on
            <strong> {sourceLabel[paper.source] ?? paper.source}</strong>. The PDF and
            authoritative metadata live there; we surface a lightweight
            reading shell here so OpenXiv readers can engage with the work
            without leaving the network.
          </p>
          {upstreamHref && (
            <p>
              <a class="btn btn-sm" href={upstreamHref} target="_blank" rel="noreferrer">
                Open on {sourceLabel[paper.source] ?? paper.source} →
              </a>
            </p>
          )}
        </section>

        {paper.abstract && (
          <section class="card lens-section">
            <h2>Abstract</h2>
            <p class="body-serif">{paper.abstract}</p>
          </section>
        )}

        <section class="card lens-section" id="ai-question">
          <header style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px;">
            <h2 style="margin: 0;">One hard question to start with</h2>
            <span class="lens-ai-pill" aria-label="AI generated">AI</span>
          </header>
          <p class="muted">A skeptical reviewer's opening question — generated by an LLM, not endorsed by the authors.</p>
          <p id="lens-ai-question" class="body-serif" style="min-height: 1.6em;">
            <em class="muted">Loading…</em>
          </p>
          <p class="muted" style="font-size: 12px;">
            If you have a better question, your seminar engagement will surface it once this paper is claimed and joined to the OpenXiv layer.
          </p>
        </section>

        <section class="card lens-section">
          <h2>Trust signals</h2>
          <p class="muted">
            Lens views show no Trust Passport — those signals require an
            OpenXiv-side submission. Once an author <strong>claims</strong> this paper
            with a verified identity, the four trust lanes apply.
          </p>
        </section>

        <section class="card lens-section">
          <h2>Is this your paper?</h2>
          {paper.claimedByDid ? (
            <p class="muted">
              Claimed by <code>{paper.claimedByDid}</code>{' '}
              {paper.claimedAt && <span>on {paper.claimedAt.slice(0, 10)}</span>}.
            </p>
          ) : (
            <>
              <p class="muted">
                Claim it to add disclosure, summaries at three reading levels,
                and accept endorsements. The PDF stays on {sourceLabel[paper.source] ?? paper.source};
                the OpenXiv layer attaches metadata and review.
              </p>
              <button
                class="btn btn-primary"
                id="lens-claim-btn"
                type="button"
                data-source={paper.source}
                data-source-id={paper.sourceId}
              >
                Claim this paper
              </button>
              <p id="lens-claim-status" class="muted" style="font-size: 12px;"></p>
            </>
          )}
        </section>
      </article>
    )}
  </main>
</Base>

<script
  is:inline
  set:html={`
    (function () {
      var source = ${JSON.stringify(sourceParam)};
      var id = ${JSON.stringify(idParam)};

      async function loadQuestion() {
        var el = document.getElementById('lens-ai-question');
        if (!el) return;
        try {
          var res = await fetch('/api-proxy/lens/' + encodeURIComponent(source) + '/' + encodeURIComponent(id) + '/ai-question');
          if (!res.ok) {
            el.innerHTML = '<em class="muted">Question generator is offline; check back later.</em>';
            return;
          }
          var data = await res.json();
          if (data && data.question) {
            el.textContent = data.question;
          } else {
            el.innerHTML = '<em class="muted">No question available yet (e.g. the abstract was empty).</em>';
          }
        } catch (e) {
          el.innerHTML = '<em class="muted">Could not load the question.</em>';
        }
      }

      var btn = document.getElementById('lens-claim-btn');
      if (btn) {
        btn.addEventListener('click', async function () {
          var status = document.getElementById('lens-claim-status');
          status.textContent = 'Claiming…';
          try {
            var res = await fetch('/api-proxy/lens/' + encodeURIComponent(source) + '/' + encodeURIComponent(id) + '/claim', {
              method: 'POST',
              credentials: 'include',
              headers: { 'content-type': 'application/json' },
              body: '{}',
            });
            if (res.status === 401) {
              status.innerHTML = 'Please <a href="/auth/sign-in">sign in</a> first.';
              return;
            }
            if (!res.ok) throw new Error('HTTP ' + res.status);
            status.textContent = 'Claimed. Reloading…';
            setTimeout(function () { location.reload(); }, 500);
          } catch (e) {
            status.textContent = 'Claim failed: ' + ((e && e.message) || 'unknown');
          }
        });
      }

      loadQuestion();
    })();
  `}
/>

<style>
  .lens-trail { margin: 0 0 12px; font-size: 13px; }
  .lens { max-width: 760px; margin: 0 auto; padding-bottom: 60px; }
  .lens-head {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .lens-source {
    padding: 2px 10px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
    border-radius: 999px;
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .lens-id { font-family: var(--font-mono); font-size: 12px; }
  .lens-withdrawn {
    padding: 2px 8px;
    background: color-mix(in srgb, var(--tone-caution) 14%, transparent);
    color: var(--tone-caution);
    border-radius: 999px;
    font-size: 11px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .lens-title { margin: 0 0 6px; }
  .lens-byline { margin: 0 0 6px; font-size: 14px; }
  .lens-cats code { font-family: var(--font-mono); font-size: 12px; }

  .lens-section { padding: 16px 18px; margin-top: 14px; }
  .lens-section h2 { margin: 0 0 8px; font-family: var(--font-serif); font-size: 15px; }
  .lens-ai-pill {
    padding: 2px 8px;
    background: color-mix(in srgb, var(--tone-warning) 18%, transparent);
    color: var(--tone-warning);
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
