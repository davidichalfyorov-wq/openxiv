---
import Base from '../layouts/Base.astro';

Astro.response.status = 404;
---

<Base
  title="Page not found — OpenXiv"
  description="The requested OpenXiv page was not found."
>
  <section class="container error-page">
    <p class="eyebrow">404</p>
    <h1 class="title-serif">Page not found</h1>
    <p class="muted error-copy">
      The page may have moved, the identifier may be incomplete, or the paper has not been
      published yet.
    </p>
    <div class="row error-actions">
      <a class="btn btn-primary" href="/search">Search OpenXiv</a>
      <a class="btn" href="/">Go to feed</a>
    </div>
  </section>
</Base>

<style>
  .error-page {
    min-height: 48vh;
    display: grid;
    align-content: center;
    gap: 14px;
    padding-block: 64px;
  }
  .error-page h1 {
    margin: 0;
    font-size: clamp(38px, 7vw, 72px);
  }
  .error-copy {
    max-width: 620px;
    font-size: 18px;
    line-height: 1.6;
  }
  .error-actions {
    gap: 10px;
    flex-wrap: wrap;
  }
</style>

