---
import Base from '../../layouts/Base.astro';
import BriefBlock from '../../components/BriefBlock.astro';
import type { BriefResponse } from '../../lib/brief';

const apiBase =
  (typeof process !== 'undefined' && process.env?.INTERNAL_API_BASE) ||
  import.meta.env.PUBLIC_API_BASE ||
  'http://localhost:4000';

let data: BriefResponse | null = null;
let error: string | null = null;
try {
  const res = await fetch(`${apiBase}/api/daily-brief`, { signal: AbortSignal.timeout(5000) });
  if (res.ok) data = await res.json();
  else error = `API ${res.status}`;
} catch (e) {
  error = (e as Error).message;
}
---
<Base title="Daily Science Brief — OpenXiv" description="Five hand-picked items: featured, claim, open question, explainer, serendipity. A finite read.">
  <main class="container">
    <header class="brief-head">
      <h1 class="title-serif">Daily Science Brief</h1>
      <p class="muted">
        Five items a day. A featured pick, a fresh claim, an open question,
        an explainer, and something serendipitous. When you reach the bottom,
        you're done — go think.
      </p>
      {data && <p class="muted brief-date">{data.date}</p>}
    </header>

    {error && (
      <article class="card" style="border-color: var(--tone-caution);">
        <strong>Brief unavailable.</strong>
        <p class="muted" style="margin: 6px 0 0;">{error}</p>
      </article>
    )}

    {data && <BriefBlock items={data.items} />}
  </main>
</Base>

<style>
  .brief-head { margin-bottom: 20px; }
  .brief-head h1 { margin: 0 0 6px; }
  .brief-date { margin: 8px 0 0; font-family: var(--font-mono); font-size: 13px; }
</style>
