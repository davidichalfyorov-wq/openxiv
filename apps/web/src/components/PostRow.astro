---
import { relativeTime } from '../lib/format';

interface Props {
  post: {
    id: string;
    uri: string;
    authorDid: string;
    text: string;
    embedPaperUri: string | null;
  };
  createdAt: string;
}

const { post, createdAt } = Astro.props;
const authorLabel = post.authorDid.startsWith('did:')
  ? post.authorDid.slice(0, 15) + '...'
  : post.authorDid;
---
<article class="post-card">
  <div class="post-header">
    <div class="post-author-info">
      <span class="post-bubble-icon">💬</span>
      <a href={`/profile/${encodeURIComponent(post.authorDid)}`} class="post-author-link" title={post.authorDid}>
        <code>{authorLabel}</code>
      </a>
    </div>
    <span class="post-time">{relativeTime(createdAt)}</span>
  </div>
  <div class="post-content">
    <p>{post.text}</p>
  </div>
  {post.embedPaperUri && (
    <div class="post-footer">
      <a href={`/paper/${encodeURIComponent(post.embedPaperUri)}`} class="post-embed-link">
        <span class="embed-icon">↪</span> References paper
      </a>
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 14px 20px;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: background-color 150ms ease;
  }

  .post-card:hover {
    background: var(--bg-hover);
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
  }

  .post-author-info {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-bubble-icon {
    font-size: 14px;
    opacity: 0.8;
  }

  .post-author-link {
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 120ms ease;
  }

  .post-author-link:hover {
    color: var(--accent);
  }

  .post-author-link code {
    font-family: var(--font-mono);
    background: var(--bg-elev);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .post-time {
    color: var(--text-tertiary);
  }

  .post-content {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-primary);
    white-space: pre-wrap;
  }

  .post-content p {
    margin: 0;
  }

  .post-footer {
    display: flex;
    align-items: center;
    border-top: 1px dashed var(--border);
    padding-top: 10px;
    margin-top: 4px;
  }

  .post-embed-link {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
    transition: color 120ms ease;
  }

  .post-embed-link:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }

  .embed-icon {
    font-size: 14px;
  }
</style>
