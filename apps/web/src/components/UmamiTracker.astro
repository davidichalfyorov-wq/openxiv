---
import { readConsentFromHeader } from '@openxiv/shared';

/**
 * Self-hosted Umami pageview tracker. Two gates:
 *
 *   1. Config gate: if PUBLIC_UMAMI_SCRIPT_URL or PUBLIC_UMAMI_WEBSITE_ID is
 *      empty, emit nothing. This is the default in dev and keeps the layout
 *      working on a fresh clone before any analytics are provisioned.
 *   2. Consent gate: if the request's `openxiv_consent` cookie does not
 *      grant `analytics`, emit nothing. Umami is privacy-friendly (no
 *      cookies, no IP tracking by default) but the project still respects
 *      the analytics consent bucket the same way the homegrown event
 *      tracker does.
 *
 * Script source: https://analytics.openxiv.net/script.js, hosted by the
 * Umami container behind Caddy (see Caddyfile.production and
 * docker-compose.production.yml). The website id is the UUID generated by
 * the Umami dashboard when the operator first registers openxiv.net as a
 * tracked property.
 */

const SCRIPT_URL = (import.meta.env.PUBLIC_UMAMI_SCRIPT_URL ?? '') as string;
const WEBSITE_ID = (import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ?? '') as string;
const configured = SCRIPT_URL.length > 0 && WEBSITE_ID.length > 0;

const cookieHeader = Astro.request.headers.get('cookie');
const consent = readConsentFromHeader(cookieHeader);
const analyticsOk = consent?.analytics === true;

const renderScript = configured && analyticsOk;
---

{renderScript && (
  <script
    is:inline
    defer
    src={SCRIPT_URL}
    data-website-id={WEBSITE_ID}
  />
)}
