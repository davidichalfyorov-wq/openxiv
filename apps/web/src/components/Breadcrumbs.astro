---
/**
 * Reusable breadcrumb trail. Renders a visible `<nav aria-label="Breadcrumb">`
 * row above the page heading and emits a `BreadcrumbList` JSON-LD payload
 * with the same items, so Google's AI Mode and Bing Generative surfaces
 * can lift the breadcrumb path into the answer card and link backwards
 * to category pages.
 *
 * Each `url` is resolved against the public origin so the JSON-LD `item`
 * field is always an absolute URL — the schema.org spec accepts either,
 * but answer engines have historically been pickier about relative paths.
 *
 * The visible row uses the project's existing text-tertiary / muted token
 * palette so no new CSS tokens are introduced.
 */
import { safeJsonLd } from '../lib/jsonld';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const publicBase = 'https://openxiv.net';
function abs(url: string): string {
  if (/^https?:\/\//i.test(url)) return url;
  return new URL(url, publicBase).toString();
}

const ld = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((it, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: it.name,
    item: abs(it.url),
  })),
};
---

{items.length > 0 && (
  <>
    <script is:inline type="application/ld+json" set:html={safeJsonLd(ld)} />
    <nav class="openxiv-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {items.map((it, i) => (
          <li>
            {i < items.length - 1 ? (
              <a href={it.url}>{it.name}</a>
            ) : (
              <span aria-current="page">{it.name}</span>
            )}
            {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
          </li>
        ))}
      </ol>
    </nav>
  </>
)}

<style>
  .openxiv-breadcrumbs {
    margin: 0 0 12px;
    font-size: 13px;
    color: var(--text-tertiary);
  }
  .openxiv-breadcrumbs ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .openxiv-breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .openxiv-breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }
  .openxiv-breadcrumbs a:hover {
    color: var(--text-primary);
    text-decoration: underline;
  }
  .openxiv-breadcrumbs [aria-current='page'] {
    color: var(--text-primary);
  }
  .openxiv-breadcrumbs .sep {
    color: var(--text-tertiary);
    opacity: 0.6;
  }
</style>
