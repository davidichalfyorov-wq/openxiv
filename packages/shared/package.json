{
  "name": "@openxiv/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "default": "./dist/result.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js",
      "default": "./dist/env.js"
    },
    "./categories": {
      "types": "./dist/categories.d.ts",
      "import": "./dist/categories.js",
      "default": "./dist/categories.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "import": "./dist/ids.js",
      "default": "./dist/ids.js"
    },
    "./submission-terms": {
      "types": "./dist/submission-terms.d.ts",
      "import": "./dist/submission-terms.js",
      "default": "./dist/submission-terms.js"
    },
    "./licenses": {
      "types": "./dist/licenses.d.ts",
      "import": "./dist/licenses.js",
      "default": "./dist/licenses.js"
    },
    "./trust": {
      "types": "./dist/trust.d.ts",
      "import": "./dist/trust.js",
      "default": "./dist/trust.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "neverthrow": "^8.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "AGPL-3.0-or-later"
}
