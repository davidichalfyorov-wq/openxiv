{
  "lexicon": 1,
  "id": "app.openxiv.summary",
  "description": "Plain-language summary attached to a paper. Required for every paper; readable at school/undergrad/expert tiers.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["paperUri", "tier", "text", "createdAt"],
        "properties": {
          "paperUri": { "type": "string", "format": "at-uri" },
          "tier": {
            "type": "string",
            "knownValues": ["school", "undergrad", "expert"]
          },
          "text": { "type": "string", "minLength": 80, "maxLength": 4000 },
          "aiGenerated": { "type": "boolean", "default": false },
          "aiModel": { "type": "string", "maxLength": 100 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
